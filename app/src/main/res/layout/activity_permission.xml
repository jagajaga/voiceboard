<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141A12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎤"
            android:textSize="64sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VoiceBoard Setup"
            android:textColor="#E8EDE3"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1: grant microphone access.\nStep 2: enable VoiceBoard in Settings.\nStep 3: paste your OpenAI key below."
            android:textColor="#7A8A74"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Step 1: mic permission -->
        <Button
            android:id="@+id/btnGrant"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Grant Microphone Permission"
            android:textColor="#E8EDE3"
            android:backgroundTint="#3A4438"
            android:layout_marginBottom="12dp" />

        <!-- Step 2: enable IME -->
        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Open Input Method Settings"
            android:textColor="#E8EDE3"
            android:backgroundTint="#2D3830"
            android:layout_marginBottom="28dp" />

        <!-- Step 3: API key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OpenAI API Key"
            android:textColor="#A8B4A2"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-..."
            android:textColor="#E8EDE3"
            android:textColorHint="#4A5A44"
            android:background="#1E2820"
            android:padding="12dp"
            android:inputType="textPassword"
            android:imeOptions="actionDone"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnSaveKey"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Key"
            android:textColor="#E8EDE3"
            android:backgroundTint="#3A4438"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvKeyStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#7A9A74"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
