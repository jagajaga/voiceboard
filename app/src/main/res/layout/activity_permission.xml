<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎤"
        android:textSize="64sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VoiceBoard"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap below to grant microphone access,\nthen enable VoiceBoard in Settings."
        android:textColor="#AAAACC"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnGrant"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Grant Microphone Permission"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3A3A6E"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Open Input Method Settings"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A5E" />

</LinearLayout>
